{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "inlineSources": false,
    "types": [],
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "scripts"],
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
