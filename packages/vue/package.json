{
  "name": "@maillayers/vue-email-editor",
  "version": "0.1.0",
  "description": "Vue 3 SDK for embedding the MailLayers email editor",
  "license": "MIT",
  "author": "MailLayers",
  "homepage": "https://docs.maillayers.com/vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maillayers/maillayers-client-sdks.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/Maillayers/maillayers-client-sdks/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync:shared": "node ../../scripts/sync-shared.mjs packages/vue/src/shared",
    "build": "npm run sync:shared && tsup",
    "build:publish": "npm run sync:shared && tsup",
    "clean": "rm -rf dist src/shared",
    "test": "npm run sync:shared && node scripts/test-component.mjs && node scripts/test-package-consumers.mjs",
    "lint": "npm run sync:shared && node scripts/lint.mjs",
    "typecheck": "npm run sync:shared && tsc --noEmit",
    "prepack": "npm run build:publish",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build:publish"
  },
  "keywords": [
    "maillayers",
    "email",
    "builder",
    "vue",
    "sdk",
    "iframe",
    "template"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.7.3",
    "vite": "^8.1.5",
    "vue": "^3.5.13"
  }
}
